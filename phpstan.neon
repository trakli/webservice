includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/nesbot/carbon/extension.neon

parameters:
    excludePaths:
        - app/Http/Resources/*
    reportUnmatchedIgnoredErrors: false

    # Ignore specific error patterns
    ignoreErrors:
        - '#PHPDoc tag @SuppressWarnings#'
        - '#Trait App\\Mcp\\Auth\\McpAuthorizationTrait is used zero times and is not analysed\.#'
