APP_NAME=Trakli
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

PLUGIN_ENGINE_LOG_CHANNEL=
PLUGIN_ENGINE_LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=trakli
DB_USERNAME=trakli
DB_PASSWORD=secret

BROADCAST_DRIVER=log

# Real-time chat streaming (Laravel Reverb). Set BROADCAST_DRIVER=reverb to enable.
# In the docker stack the app reaches the server as "reverb"; the browser uses
# the published host port (REVERB_HOST_PORT, default 6001).
REVERB_APP_ID=your-reverb-app-id
REVERB_APP_KEY=your-reverb-app-key
REVERB_APP_SECRET=generate-a-secure-random-string-here
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_HOST_PORT=6001

CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@trakli.io"
MAIL_FROM_NAME="${APP_NAME}"

FRONTEND_URL=http://localhost:3001

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=${FRONTEND_URL}/auth/google/callback

SANCTUM_STATEFUL_DOMAINS=dashboard.trakli.app,localhost:3001
SESSION_DOMAIN=localhost
CORS_ALLOWED_ORIGINS=https://dashboard.trakli.app,http://localhost:3001

SMARTPINGS_CLIENT_ID=
SMARTPINGS_SECRET_ID=

# User Authentication Verification Settings
USER_AUTH_REQUIRE_EMAIL_VERIFICATION=false
USER_AUTH_REQUIRE_PHONE_VERIFICATION=false
USER_AUTH_CODE_LENGTH=6
USER_AUTH_CODE_EXPIRY_MINUTES=5
USER_AUTH_RATE_LIMIT_ATTEMPTS=3
USER_AUTH_RATE_LIMIT_MINUTES=5
USER_AUTH_VERIFICATION_PROVIDER=smartpings
USER_AUTH_SELF_MANAGED=false
USER_AUTH_ROUTE_PREFIX=api/v1
MODEL_CONFIG_ROUTE_PREFIX=api/v1
FIREBASE_CREDENTIALS=storage/app/firebase-auth.json

# LLM Configuration
#
# Two keys are required for the AI chat feature:
#   - LLM_API_KEY   : used by SmartQL (the NL-to-SQL service) via LiteLLM
#   - GEMINI_API_KEY: used by Prism (in-process classifier + general chat)
#
# They are kept separate on purpose so the NL-to-SQL layer and the
# conversational layer can be configured independently (e.g. different
# providers or keys). In practice they can be the same Gemini key.
# Both MUST be set; SmartQL will fail to start if LLM_API_KEY is empty.
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash
LLM_TEMPERATURE=0
LLM_RETRIES=3
LLM_API_KEY=
GEMINI_API_KEY=

# Docker Development Ports (optional overrides)
# APP_PORT=8000
# FORWARD_DB_PORT=3306
# FORWARD_TEST_DB_PORT=3307
# PMA_PORT=8080
# MAILHOG_SMTP_PORT=1025
# MAILHOG_UI_PORT=8025
# SMARTQL_PORT=5000

# MCP (Model Context Protocol) Configuration
MCP_ENABLED=true
MCP_ENDPOINT=/mcp/sse
MCP_AUTH_GUARD=sanctum
MCP_TOOLS_TRANSACTIONS=true
MCP_TOOLS_BUDGETS=true
MCP_TOOLS_WALLETS=true
MCP_RATE_LIMIT_ENABLED=true
MCP_RATE_LIMIT_MAX=60
MCP_RATE_LIMIT_DECAY=1
MCP_STRICT_PERMISSIONS=false
MCP_SERVER_NAME=Trakli
MCP_SERVER_VERSION=1.0.0
